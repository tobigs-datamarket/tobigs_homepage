# 로컬 개발용 예시 파일입니다. 실제 값은 절대 이 파일에 넣지 마세요.
# 1. 이 파일을 복사해서 .env 를 만들고 아래 값을 채워 넣으세요 (.env는 git에 올라가지 않습니다).
# 2. 배포용 값은 GitHub 레포 Settings > Secrets and variables > Actions 에 동일한 이름으로 등록되어 있습니다.

VITE_SITE_URL="https://www.datamarket.ai.kr"

# 구글 시트를 DB처럼 사용합니다. 각 시트는 공유 > 링크가 있는 모든 사용자 "뷰어" 로 설정 후,
# CSV export 링크를 사용합니다: https://docs.google.com/spreadsheets/d/{시트ID}/export?format=csv&gid={시트gid}
VITE_AWARDS_SHEET_CSV_URL="https://docs.google.com/spreadsheets/d/xxxxxxxx/export?format=csv&gid=0"
VITE_MEMBERS_SHEET_CSV_URL="https://docs.google.com/spreadsheets/d/xxxxxxxx/export?format=csv&gid=0"
